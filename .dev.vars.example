# Copy to `.dev.vars` for local `wrangler dev` (never commit `.dev.vars`).
ADMIN_PASSWORD=change-me
# Session cookie HMAC key (required for login; independent of ADMIN_PASSWORD)
SESSION_SECRET=change-me-session-secret
# Comma-separated SPA origins allowed for credentialed CORS (production app URL)
# CORS_ALLOWED_ORIGINS=https://your-app.example.com
ADMIN_PATH=admin
